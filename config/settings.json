{
  "version": "1.2.0",
  "autostart": true,
  "theme": "dark",
  "language": "fr",
  "backup": {
    "mode": "shutdown",
    "scheduled_time": "03:30",
    "target_disk": "",
    "source_disks": []
  },
  "filters": {
    "excluded_extensions": [
      ".tmp",
      ".log",
      ".DS_Store",
      "Thumbs.db"
    ],
    "excluded_folders": [
      "node_modules",
      "__pycache__",
      "$RECYCLE.BIN",
      "System Volume Information",
      ".git"
    ],
    "max_size_bytes": 0
  },
  "restore": {
    "default_destination": "original",
    "context_menu": true
  },
  "ui": {
    "close_behavior": "minimize"
  }
}